# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/pulse"

# Auth
NEXTAUTH_SECRET="your-generated-secret"
NEXTAUTH_URL="http://localhost:3000"

# Google Places API
# Also used for the Geocoding API (event lat/lng). Enable the "Geocoding API"
# library on this key's Google Cloud project (separate from Places).
GOOGLE_PLACES_API_KEY="your-google-places-api-key"

# OpenAI (for AI enrichment)
OPENAI_API_KEY="your-openai-api-key"

# Vercel Blob Storage (for file uploads)
# Get this from your Vercel project settings > Storage > Blob
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# Scraper Cron Secret (for automated event scraping)
CRON_SECRET="your-cron-secret"
